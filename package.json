{
  "name": "reporting-portfolio-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --prefix ../reporting && vite build",
    "build:client": "vite build",
    "start": "node server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server.js",
    "dev:client": "vite",
    "test": "node --test 'test/*.js'",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/react": "^1.0.0",
    "@reporting/core": "file:../reporting/packages/core",
    "@reporting/mcp-server": "file:../reporting/packages/mcp-server",
    "@reporting/react-ui": "file:../reporting/packages/react-ui",
    "ai": "^5.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "vite": "^5.0.0"
  }
}
