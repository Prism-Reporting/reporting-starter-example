# Required for prompt-driven report generation (POST /api/chat).
OPENAI_API_KEY=

# Optional: model for the report-generation agent (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional: MCP server URL when using a remote reporting MCP server. Omit for the default in-process MCP.
# REPORTING_MCP_URL=
